# Local emulator: .env.example then .env (override).
# Production: set in Firebase/Google Cloud for the functions service.
GEMINI_API_KEY=
USDA_API_KEY=
# Optional — model id for REST generateContent (must exist for your API key).
# Default: gemini-3.1-flash-lite-preview
# Other options: gemini-3.1-pro-preview, gemini-3-flash-preview
# GEMINI_MODEL=gemini-3.1-flash-lite-preview
