{
  "name": "enterprise-ai-transformation",
  "private": true,
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nuvear/rajagobalan-site.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/copy-discipline.mjs && node scripts/copy-foodie.mjs",
    "preview": "vite preview",
    "deploy": "npm run build && firebase deploy --only hosting",
    "deploy:discipline": "npm run build && firebase deploy --only hosting,firestore,functions",
    "local": "npm run build && concurrently -k \"npm:local:emulators\" \"npm:local:preview\"",
    "local:emulators": "firebase emulators:start --only functions",
    "local:preview": "vite preview --port 4173 --strictPort"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.2.1",
    "firebase-tools": "^15.9.0",
    "vite": "^5.0.0"
  }
}
